PORT=3000
NODE_ENV=development

# Firebase Admin - Download service account from Firebase Console > Project Settings > Service Accounts
# Place the JSON file as firebase-service-account.json in project root
FIREBASE_SERVICE_ACCOUNT=./firebase-service-account.json

# Optional: Beem SMS API (for admin withdrawal notifications)
BEEM_API_KEY=
BEEM_SECRET_KEY=
BEEM_SOURCE_ADDR=
BEEM_DEST_ADDR=
